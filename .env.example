# ─────────────────────────────────────────────────────────────
# Base de datos (Neon Postgres). Usa la connection string POOLED
# (la que trae `-pooler` en el host) para funciones serverless.
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/tienda?sslmode=require"

# ─────────────────────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"

# TEMPORAL: "true" simula compras exitosas sin pasarela (para probar el flujo
# completo). Ponlo en "false" al integrar Mercado Pago / PayPal.
SIMULATE_PAYMENTS="false"

# ─────────────────────────────────────────────────────────────
# Correos (Resend)
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxx"
# Remitente. Pruebas: "Tienda Nume <onboarding@resend.dev>" (solo entrega al
# correo de tu cuenta Resend). Producción: un remitente de tu DOMINIO VERIFICADO
# en Resend, p. ej. "Tienda Nume <pedidos@numerologia-cotidiana.com>".
EMAIL_FROM="Tienda Nume <onboarding@resend.dev>"
# Opcional: a dónde llegan las respuestas de los clientes.
EMAIL_REPLY_TO=""

# ─────────────────────────────────────────────────────────────
# Generador de reportes (Railway). Sin estas dos, los reportes se
# marcan "skipped" y el resto de la compra funciona normal.
# ─────────────────────────────────────────────────────────────
REPORT_GENERATOR_URL="https://<tu-servicio>.up.railway.app"
REPORT_WEBHOOK_SECRET="<el mismo WEBHOOK_SECRET de Railway>"
# Protege el cron /api/cron/reports (Vercel Cron manda este Bearer).
CRON_SECRET="un-secreto-largo-y-aleatorio"

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3002"
NEXT_PUBLIC_STORE_NAME="Tienda Nume"

# Impuesto fijo aplicado al subtotal (0.16 = 16%). 0 = sin impuesto.
DEFAULT_TAX_RATE="0.16"
# Moneda por defecto (ISO 4217).
DEFAULT_CURRENCY="USD"

# Secreto para firmar los tokens de descarga de productos digitales.
DOWNLOAD_TOKEN_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# ─────────────────────────────────────────────────────────────
# Panel admin (/admin)
# ADMIN_PASSWORD: lo que escribes al entrar.
# ADMIN_TOKEN: valor de sesión que se guarda en la cookie (pon algo largo/aleatorio).
# ─────────────────────────────────────────────────────────────
# Correo + contraseña para entrar a /admin.
# Nota: en .env.local, si la contraseña tiene "$", escápalo como "\$"
# (Next.js expande variables). En Vercel se pone tal cual, sin escape.
ADMIN_EMAIL="administracion@tu-dominio.com"
ADMIN_PASSWORD="cambia-esta-contraseña"
ADMIN_TOKEN="cambia-esto-por-un-token-largo-y-aleatorio"

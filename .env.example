# ─────────────────────────────────────────────────────────────
# Base de datos (Neon Postgres). Usa la connection string POOLED
# (la que trae `-pooler` en el host) para funciones serverless.
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/tienda?sslmode=require"

# ─────────────────────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"

# TEMPORAL: "true" simula compras exitosas sin pasarela (para probar el flujo
# completo). Ponlo en "false" al integrar Mercado Pago / PayPal.
SIMULATE_PAYMENTS="false"

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3002"
NEXT_PUBLIC_STORE_NAME="Tienda Nume"

# Impuesto fijo aplicado al subtotal (0.16 = 16%). 0 = sin impuesto.
DEFAULT_TAX_RATE="0.16"
# Moneda por defecto (ISO 4217).
DEFAULT_CURRENCY="USD"

# Secreto para firmar los tokens de descarga de productos digitales.
DOWNLOAD_TOKEN_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# ─────────────────────────────────────────────────────────────
# Panel admin (/admin)
# ADMIN_PASSWORD: lo que escribes al entrar.
# ADMIN_TOKEN: valor de sesión que se guarda en la cookie (pon algo largo/aleatorio).
# ─────────────────────────────────────────────────────────────
ADMIN_PASSWORD="cambia-esta-contraseña"
ADMIN_TOKEN="cambia-esto-por-un-token-largo-y-aleatorio"
